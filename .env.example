# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────────────
# Local development (SQLite file):
DATABASE_URL="file:./dev.db"

# Production with Turso (copy from: turso db show riskops-demo --url):
# DATABASE_URL="libsql://riskops-demo-<org>.turso.io"

# ── Turso auth token (leave empty for local SQLite) ───────────────────────────
# Production (copy from: turso db tokens create riskops-demo):
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# ── Session secret ────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required in production — app will throw on startup if missing.
SESSION_SECRET="riskops-dev-secret-change-in-production!!"

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Set to "true" to show the demo banner and block destructive admin actions.
# Normal demo workflows remain fully enabled (KYC, alerts, cases, SAR, import/
# export). This is NOT full read-only mode — safe for live demos with real users.
# Omit or set to "false" for a standard deployment.
DEMO_MODE="true"

# ── Anthropic API key (optional — powers AI case summary) ────────────────────
# Leave unset to disable the feature. When DEMO_MODE=true the summary panel
# displays a warning that results are based on mock data only.
ANTHROPIC_API_KEY="your-anthropic-api-key"
