# Copy this file to .env and fill in your values
# cp .env.example .env

# SQLite (local development — file path relative to project root)
DATABASE_URL="file:./dev.db"

# For production with Turso / libSQL, use a remote URL instead:
# DATABASE_URL="libsql://your-db.turso.io"
# DATABASE_AUTH_TOKEN="your-auth-token"

# Session secret — must be at least 32 characters
SESSION_SECRET="riskops-dev-secret-change-in-production!!"

# Anthropic API key — required for AI case summary feature
ANTHROPIC_API_KEY="your-anthropic-api-key"
